format PE console

entry start
include 'win32a.inc'

macro qsr.printf message
{
    push ebx
    mov edi, message
    call qsr_len_string
    push 0
    push qsr.Console.ConsoleTempPtr
    push ebx
    push edi
    push [qsr.Console.ConsoleHandle]
    call [WriteConsoleA]
    pop ebx
}
macro qsr.printfl message
{
	push message
	push strFormat
	call [printf]
	add esp, 8
	Console.endl
}
macro qsr.printc 
{
	mov [qsr.Console.ConsoleChar], al
 
    push ebx
    push 0
    push qsr.Console.ConsoleTempPtr
    push 1
    push qsr.Console.ConsoleChar
    push [qsr.Console.ConsoleHandle]
    call [WriteConsoleA]
    pop ebx
}
macro qsr.printv message
{
	push message
	push varFormat
	call [printf]
	add esp, 8
}
macro qsr.printva message
{
	push ebx
    push eax
    mov eax, [message]
    call qsr_uint_to_str
    call qsr_len_string
    push 0
    push qsr.Console.ConsoleTempPtr
    push ebx
    push edi
    push [qsr.Console.ConsoleHandle]
    call [WriteConsoleA]
    pop eax
    pop ebx
}
macro qsr.printvaf message
{
	sub esp, 8
    fld dword [message]
    fstp qword [esp]
    push floatFormat
    call [printf]
    add esp, 12
}
macro Console.getch 
{
	call [getch]
}
macro Console.endl 
{
	push endl
	push strFormat
	call [printf]
	add esp, 8
}
macro Console.cin var
{
	lea eax, [var]
	push eax
	push varFormat
	call [scanf]
	add esp, 8
}
macro Console.clear 
{
	invoke  WriteConsoleA, [qsr.Console.ConsoleHandle], clear, 6, qsr.Console.ConsoleTempPtr, 0
}
macro Array.init list,len,size
{
	lea ecx, [list]
	mov [ecx], esp
    mov eax, size
	mov ebx, len
	imul eax, ebx
	sub esp, eax
	mov eax, len
	
	lea ecx, [list]
	add ecx, 4
	mov [ecx], dword eax
	
	lea ecx, [list]
	add ecx, 8
    mov [ecx], dword size
}
macro Array.clear list
{
	mov eax, [list.Count]
	mov ebx, [list.ItemSize]
	imul eax, ebx
	add esp, eax
	mov [list.Items], 0
	mov [list.Count], 0
	mov [list.ItemSize], 0
}
macro qsr.GetConsoleHandle 
{
    invoke GetStdHandle, STD_OUTPUT_HANDLE
    mov [qsr.Console.ConsoleHandle], eax
    xor eax, eax
}
macro qsr.GetHeapHandle 
{
	invoke GetProcessHeap
	mov [qsr.Heap.Handle], eax
	
	
	
	xor eax, eax
}
macro qsr.AllocPool poolSize
{
    push dword [poolSize]
	push dword HEAP_ZERO_MEMORY
	push dword [qsr.Heap.Handle]
	call [HeapAlloc]
	
	
    
	mov [qsr.Pool.PoolPtr], eax
	mov ecx, [poolSize]
	mov [qsr.Pool.PoolMaxSize], ecx
	mov [qsr.Pool.PoolEnd], eax
}
macro qsr.PoolPrint 
{
push str_const_0
call printq_string
mov eax, [qsr.Heap.Handle]
push eax
call printq_int32
Console.endl 
push str_const_1
call printq_string
mov eax, [qsr.Pool.PoolPtr]
push eax
call printq_int32
Console.endl 
push str_const_2
call printq_string
mov eax, [qsr.Pool.PoolTotalSize]
push eax
call printq_int32
Console.endl 
push str_const_3
call printq_string
mov eax, [qsr.Pool.PoolMaxSize]
push eax
call printq_int32
Console.endl 
push str_const_4
call printq_string
mov eax, [qsr.Pool.PoolItemCount]
push eax
call printq_int32
Console.endl 
}
struct heap
    Handle dd 0
    Error dd 0
ends
struct poolFrame
    PoolPtr dd 0
    PoolMaxSize dd 0
    PoolTotalSize dd 0
    PoolEnd dd 0
    PoolItemCount dd 0
ends
struct console
    ConsoleHandle dd 0
    ConsoleBuffer dd 0
    ConsoleTempPtr dd 0
    ConsoleCharBuffer db 0
    ConsoleChar db 0
    ConsoleBytesRead dd 0
ends
struct Qsr
    Console console
    Pool poolFrame
    Heap heap
ends
struct Person
    age dd 0
ends
macro Nums.init list,len,size
{
    lea ecx, [list]
	mov [ecx], esp
    mov eax, size
	mov ebx, len
	imul eax, ebx
	sub esp, eax
	mov eax, len
	
	lea ecx, [list]
	add ecx, 4
	mov [ecx], dword eax
	
	lea ecx, [list]
	add ecx, 8
    mov [ecx], dword size
}
struct StringArray
    value dd 0
    count dd 0
    itemSize dd 0
ends
struct String
    str dd 0
ends
struct Array_int32
    Items dd 0
    Count dd 0
    ItemSize dd 0
ends
struct Nums_int32
    Items dd 0
    Count dd 0
    ItemSize dd 0
ends
struct Nums_string
    Items dd 0
    Count dd 0
    ItemSize dd 0
ends

