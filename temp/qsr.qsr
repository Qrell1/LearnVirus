mov [format],0
jmp .ConsoleWriteLine.fl
.ConsoleWriteLine.fl2: 
mov [format],1
.ConsoleWriteLine.fl: 
cmp [format],0
jne false2
mov eax,dword [data]
qsr.printf eax
false2: 
cmp [format],1
jne false3
qsr.printva data
false3: 
Console.endl 
Console.WriteLine.retn: 
ret 
endp 
