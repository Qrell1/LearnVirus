extern-func void glVertex3f (float x, float y, float z)             
extern-func void glColor3f (float r, float g, float b)              
extern-func void glColor3ub (int8 r, int8 g, int8 b)
extern-func void glColor4f (float r, float g, float b, float a)     
extern-func void glClear (int32 mask)
extern-func void glClearColor (float r, float g, float b, float a)
extern-func void glMatrixMode (int32 mode)
extern-func void glLoadIdentity ()                                  
extern-func void glOrtho (float left, float right, float bottom, float top, float near, float far) 
extern-func void glViewport (int32 x, int32 y, int32 width, int32 height)                          
extern-func void glPushMatrix ()                                    
extern-func void glPopMatrix ()                                     
extern-func void glTranslatef (float x, float y, float z)           
extern-func void glRotatef (float angle, float x, float y, float z) 
extern-func void glScalef (float x, float y, float z)               
extern-func void glPushAttrib (int32 mask)
extern-func void glPopAttrib ()
extern-func void glRasterPos2i (int32 x, int32 y) 
extern-func void glCallLists (int32 n, int32 type, int32 lists)
extern-func void glGenTextures (int32 n, int32* textures) 
extern-func void glBindTexture (int32 target, int32 texture) 
extern-func void glTexImage2D (int32 target, int32 level, int32 internalformat, int32 width, int32 height, int32 border, int32 format, int32 type, int32* pixels) 
extern-func void glTexParameteri (int32 target, int32 pname, int32 param) 
extern-func int32 glGetError () 
extern-func void glFlush () 
extern-func void glFinish ()
extern from opengl

using section {
	asm
	GL_POINTS         = 0
	GL_LINES          = 1
	GL_LINE_LOOP      = 2
	GL_LINE_STRIP     = 3
	GL_TRIANGLES      = 4
	GL_TRIANGLE_STRIP = 5
	GL_TRIANGLE_FAN   = 6
	GL_QUADS          = 7
	GL_QUAD_STRIP     = 8
	GL_POLYGON        = 9
    GL_MODELVIEW      = 0x1700
    GL_PROJECTION     = 0x1701
    GL_TEXTURE        = 0x1702
    GL_COLOR_BUFFER_BIT   = 0x4000
    GL_DEPTH_BUFFER_BIT   = 0x0100
    GL_ACCUM_BUFFER_BIT   = 0x0200
    GL_STENCIL_BUFFER_BIT = 0x0400
    GL_ALL_ATTRIB_BITS    = 0xFFFFFFFF
    GL_BYTE           = 0x1400
    GL_UNSIGNED_BYTE  = 0x1401
    GL_SHORT          = 0x1402
    GL_UNSIGNED_SHORT = 0x1403
    GL_INT            = 0x1404
    GL_UNSIGNED_INT   = 0x1405
    GL_FLOAT          = 0x1406
    GL_TEXTURE_2D     = 0x0DE1
    GL_RGB            = 0x1907
    GL_RGBA           = 0x1908
    GL_TEXTURE_MIN_FILTER = 0x2801
    GL_TEXTURE_MAG_FILTER = 0x2800
    GL_LINEAR         = 0x2601
    GL_NEAREST        = 0x2600
    PFD_DRAW_TO_WINDOW    = 0x00000004
	PFD_SUPPORT_OPENGL    = 0x00000020
	PFD_DOUBLEBUFFER      = 0x00000001
	PFD_TYPE_RGBA         = 0
	PFD_MAIN_PLANE        = 0
    GL_VERTEX_SHADER      = 0x8B31
	GL_FRAGMENT_SHADER    = 0x8B30
	GL_COMPILE_STATUS     = 0x8B81
	GL_LINK_STATUS        = 0x8B82
    GL_FRAMEBUFFER        = 0x8D40
	GL_COLOR_ATTACHMENT0  = 0x8CE0
	GL_DEPTH_ATTACHMENT   = 0x8D00
	GL_FRAMEBUFFER_COMPLETE = 0x8CD5
	asm
}
