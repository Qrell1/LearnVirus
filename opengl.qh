extern-func int32 SwapBuffers (int32 hdc)                              from gdi

extern
extern-func int32 wglCreateContext (int32 hdc)
extern-func int32 wglDeleteContext (int32 hglrc)                     
extern-func int32 wglMakeCurrent (int32 hdc, int32 hglrc) 
extern-func void glBegin (int32 mode)
extern-func void glEnd ()                                           
extern-func void glVertex2i (int32 x, int32 y)                      
