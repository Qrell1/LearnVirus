using "lib/opengl.inc";
include "openglstructs.qh";


inline CreateWindow (int32 w, int32 h)
{
	asm
    invoke CreateWindowExA,0,ClassName,WindowTitle,\
           WS_VISIBLE+WS_OVERLAPPEDWINDOW,\
           100,100,w,h,0,0,[Instance],0
    asm
}

//int32 Instance;

class Window {

     int32 Style
	 int32 lpfnWndProc
	 int32 cbClsExtra
	 int32 cbWndExtra
	 int32 hInstance
	 int32 hIcon
	 int32 hCursor
	 int32 hbrBackground
	 string* lpszMenuName
	 string* lpszClassName
	 int32 hWindow

    void Create (int32 w, int32 h, string* className, string* windowTitle)
	{
		asm
		push ebx
        push esi
        push edi
        asm

        this.lpszClassName = className
        this.lpszMenuName = windowTitle

        asm
		mov eax, WindowProc
        mov [edx + Window.lpfnWndProc], eax
		asm

		asm
	    invoke GetModuleHandleA,0
        mov [edx + Window.hInstance],eax
		//mov ecx, [this]
		push edx
        call [RegisterClassA]
	    asm
		asm
		mov edx, [this]
		mov eax, [edx + Window.lpszClassName]
		mov ebx, [edx + Window.lpszMenuName]

        //mov ecx, [this]
		push 0         
        push [edx + Window.hInstance]                                
        push 0                
        push 0
        push [h]
        push [w]
        push 100                                   
        push 100                                  
        push WS_VISIBLE+WS_OVERLAPPEDWINDOW       
        push ebx                                  
        push eax                              
        push 0                                  
        call [CreateWindowExA]
		
	    mov [edx + Window.hWindow], eax

        pop edi
        pop esi
        pop ebx
		//push eax
        //push GWL_USERDATA
		//lea ecx, [this]
        //push ecx
        //call [SetWindowLongPtrA]

        mov eax, [this]
		mov [WindowContext + SystemWindowContext.window], eax
		asm
	}
    void OnUpdate ()
	{
		
	}
	void OnResize ()
	{
		printq @string ("OnResize") Console.endl()
	}
}

class OpenGlContext {
	int32 hDC
    int32 hRC
    int32 width
    int32 height
    PixelFormatDescriptor pfd

    void InitOpenGl (int32 hWindow, int32 w, int32 h)
	{
	asm
	    mov eax, [w]
		mov [this + OpenGlContext.width], eax
		mov eax, [h]
		mov [this + OpenGlContext.height], eax

        mov eax, [hWindow]
		push eax
        call [GetDC]
        mov [this + OpenGlContext.hDC], eax

        lea edx, [this + OpenGlContext.pfd]
        mov [edx + PixelFormatDescriptor.nSize], 40
        mov [edx + PixelFormatDescriptor.nVersion], 1
		mov eax, PFD_DRAW_TO_WINDOW or PFD_SUPPORT_OPENGL or PFD_DOUBLEBUFFER
        mov [edx + PixelFormatDescriptor.dwFlags], eax
        mov [edx + PixelFormatDescriptor.iPixelType], PFD_TYPE_RGBA
        mov [edx + PixelFormatDescriptor.cColorBits], 32
        mov [edx + PixelFormatDescriptor.cDepthBits], 16
        mov [edx + PixelFormatDescriptor.iLayerType], PFD_MAIN_PLANE
        
        lea eax, [this + OpenGlContext.pfd]
        push eax
        push [this + OpenGlContext.hDC]
        call [ChoosePixelFormat]
        
        lea ebx, [this + OpenGlContext.pfd]
        push ebx
        push eax
        push [this + OpenGlContext.hDC]
        call [SetPixelFormat]
        
        push [this + OpenGlContext.hDC]
        call [wglCreateContext]
        mov [this + OpenGlContext.hRC], eax
        
        push eax
        push [this + OpenGlContext.hDC]
        call [wglMakeCurrent]
		mov eax, [this]
		mov [WindowContext.context], eax
    asm
	}

    void MakeCurrent ()
    {
    asm
        push [this + OpenGlContext.hRC]
        push [this + OpenGlContext.hDC]
        call [wglMakeCurrent]
		mov eax, [this]
		mov [WindowContext.context], eax
    asm
    }

    void SwapBuffers ()
    {
    asm
        push [this + OpenGlContext.hDC]
        call [SwapBuffers]
    asm
    }

    void Clear()// (float r, float g, float b)
    {
    asm
        //push 1.0
        //push [b]
        //push [g]
        //push [r]
        //call [glClearColor]
        
        push GL_COLOR_BUFFER_BIT
        call [glClear]
    asm
    }
}
void WindowProc (int32 hwnd, int32 wmsg, int32 wparam, int32 lparam)
{
	asm
	cmp [wmsg],WM_DESTROY
    je .wmdestroy
	cmp [wmsg],WM_SIZE
	je .wmsize
	cmp [wmsg],WM_PAINT
	je .wmpaint
	asm
	WindowContext.window.OnUpdate() // Update Window
    asm
    invoke DefWindowProcA,[hwnd],[wmsg],[wparam],[lparam]
    ret
.wmpaint:
    mov eax, [WindowContext.context]
	cmp eax, 0

    jne .f1
    xor eax, eax
	ret
    .f1:
      
    push [eax + OpenGlContext.hRC]
    push [eax + OpenGlContext.hDC]
    call [wglMakeCurrent]
	
    push 1.0        // alpha
    push 0.0        // blue
    push 1.0        // green
    push 1.0        // red
    call [glClearColor]
    
    push GL_COLOR_BUFFER_BIT
    call [glClear]
        
    mov edx, [WindowContext.context]
	mov eax, [edx + OpenGlContext.hDC]
	push eax
    call [SwapBuffers]
        
    //push 0
    //push [hwnd]
    //call [ValidateRect]
    xor eax, eax
    ret
.wmdestroy:
    invoke PostQuitMessage,0
    xor eax,eax
.wmsize:
    mov eax, [lparam]
    movzx ecx, ax      
    shr eax, 16             
    movzx edx, ax        

    asm
	WindowContext.window.OnResize()
    asm
    //invoke glViewport, 0, 0, ecx, edx
    
    //invoke glMatrixMode, GL_PROJECTION
    //invoke glLoadIdentity
    //invoke glOrtho, 0, ecx, edx, 0, -1, 1  ; для 2D игр
    //invoke glMatrixMode, GL_MODELVIEW
    
    //invoke InvalidateRect, [hwnd], 0, 1
    xor eax, eax
    ret
    asm
}

struct SystemWindowContext {
	Window* window
	OpenGlContext* context
}

SystemWindowContext WindowContext?


extern-library opengl "opengl32.dll"
extern-library glu "glu32.dll"
extern-library gdi "gdi32.dll"

