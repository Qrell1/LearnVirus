format PE console

entry start
include 'win32a.inc'

macro qsr.printf message
{
    push ebx
    mov edi, message
    call qsr_len_string
    push 0
    push qsr.Console.ConsoleTempPtr
    push ebx
    push edi
    push [qsr.Console.ConsoleHandle]
    call [WriteConsoleA]
    pop ebx
}
macro qsr.printfl message
{
	push message
	push strFormat
	call [printf]
	add esp, 8
	Console.endl
}
macro qsr.printc 
{
	mov [qsr.Console.ConsoleChar], al
 
    push ebx
    push 0
    push qsr.Console.ConsoleTempPtr
    push 1
    push qsr.Console.ConsoleChar
    push [qsr.Console.ConsoleHandle]
    call [WriteConsoleA]
    pop ebx
}
macro qsr.printv message
{
	push message
	push varFormat
	call [printf]
	add esp, 8
}
macro qsr.printva message
{
	push ebx
    push eax
    mov eax, [message]
    call qsr_uint_to_str
    call qsr_len_string
    push 0
    push qsr.Console.ConsoleTempPtr
    push ebx
    push edi
    push [qsr.Console.ConsoleHandle]
    call [WriteConsoleA]
    pop eax
    pop ebx
}
macro qsr.printvaf message
{
	sub esp, 8
    fld dword [message]
    fstp qword [esp]
    push floatFormat
    call [printf]
    add esp, 12
}
macro Console.getch 
{
	call [getch]
}
macro Console.endl 
{
	push endl
	push strFormat
	call [printf]
	add esp, 8
}
macro Console.cin var
{
	lea eax, [var]
	push eax
	push varFormat
	call [scanf]
	add esp, 8
}
macro Console.clear 
{
	invoke  WriteConsoleA, [qsr.Console.ConsoleHandle], clear, 6, qsr.Console.ConsoleTempPtr, 0
}
macro Array.init list,len,size
{
	mov [list +Array_int32.Items], esp
	mov eax, size
	mov ebx, len
	imul eax, ebx
	sub esp, eax
	mov eax, len
	mov [list +Array_int32.Count], eax
	mov [list +Array_int32.ItemSize], size
}
macro Array.clear list
{
	mov eax, [list.Count]
	mov ebx, [list.ItemSize]
	imul eax, ebx
	add esp, eax
	mov [list.Items], 0
	mov [list.Count], 0
	mov [list.ItemSize], 0
}
macro qsr.GetConsoleHandle 
{
    invoke GetStdHandle, STD_OUTPUT_HANDLE
    mov [qsr.Console.ConsoleHandle], eax
    xor eax, eax
}
macro qsr.init 
{
qsr.GetConsoleHandle 
}
struct console
    ConsoleHandle dd 0
    ConsoleBuffer dd 0
    ConsoleTempPtr dd 0
    ConsoleCharBuffer db 0
    ConsoleChar db 0
    ConsoleBytesRead dd 0
ends
struct Qsr
    Console console
ends
struct Array_int32
    Items dd 0
    Count dd 0
    ItemSize dd 0
ends
struct Nums_int32
    Items dd 0
    Count dd 0
    ItemSize dd 0
ends

