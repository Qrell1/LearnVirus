proc fibonacci nnn:DWORD
cmp [nnn],0
je true0
cmp [nnn],1
je true0
jmp false10
true0: 
mov eax,dword [nnn]
jmp fibonacci.return
jmp elses0
false10: 
mov eax,dword [nnn]
sub eax,1
push eax
call fibonacci
push eax
mov eax,dword [nnn]
sub eax,2
push eax
call fibonacci
mov ebx,eax
pop eax
add eax,ebx
jmp fibonacci.return
elses0: 
fibonacci.return: 
fibonacci.retn: 
ret 
endp 
proc printq_string data:DWORD
local format dd 0
mov [format],dword 1
local form db 0
mov [form],250
add [form],10
jc .trueP
jmp .falseP
.trueP: 
mov [format],0
.falseP: 
cmp [format],0
jne false11
mov eax,dword [data]
qsr.printf eax
false11: 
cmp [format],1
jne false12
qsr.printva data
false12: 
printq_string.retn: 
ret 
endp 
