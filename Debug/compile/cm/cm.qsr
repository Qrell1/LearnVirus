section '.code' code readable executable
proc qsr_len_string
push edi
xor ebx,ebx
.next_iter: 
cmp [edi+ebx],byte 0
je .close
inc ebx
jmp .next_iter
.close: 
pop edi
ret 
qsr_len_string.retn: 
ret 
endp 
proc qsr_uint_to_str
push ebx
push ecx
push edx
mov edi,qsr.Console.ConsoleBuffer + 11
mov byte [edi],0
dec edi
mov ebx,10
test eax,eax
jnz .convert
mov byte [edi],'0'
jmp .done
.convert: 
xor edx,edx
div ebx
add dl,'0'
mov [edi],dl
dec edi
test eax,eax
jnz .convert
.done: 
inc edi
pop edx
pop ecx
pop ebx
ret 
qsr_uint_to_str.retn: 
ret 
endp 
proc qsr.getTick var:DWORD
local resualt dd 0
invoke GetTickCount
mov [resualt],eax
mov eax,dword [resualt]
jmp qsr.getTick.return
qsr.getTick.return: 
qsr.getTick.retn: 
ret 
endp 
proc Console.Write form:DWORD ,data:DWORD
local format dd 0
mov eax,dword [form]
cmp [eax],word '%s'
je .ConsoleWrite.fl1
jne .ConsoleWrite.fl2
.ConsoleWrite.fl1: 
mov [format],0
jmp .ConsoleWrite.fl
.ConsoleWrite.fl2: 
mov [format],1
.ConsoleWrite.fl: 
cmp [format],0
jne false0
mov eax,dword [data]
qsr.printf eax
false0: 
cmp [format],1
jne false1
qsr.printva data
false1: 
Console.Write.retn: 
ret 
endp 
proc Console.WriteLine form:DWORD ,data:DWORD
local format dd 0
mov eax,dword [form]
cmp [eax],word '%s'
je .ConsoleWriteLine.fl1
jne .ConsoleWriteLine.fl2
.ConsoleWriteLine.fl1: 
mov [format],0
jmp .ConsoleWriteLine.fl
.ConsoleWriteLine.fl2: 
mov [format],1
.ConsoleWriteLine.fl: 
cmp [format],0
jne false2
mov eax,dword [data]
qsr.printf eax
false2: 
cmp [format],1
jne false3
qsr.printva data
false3: 
Console.endl 
Console.WriteLine.retn: 
ret 
endp 
