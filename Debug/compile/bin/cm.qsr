proc WindowProc hwnd:DWORD ,wmsg:DWORD ,wparam:DWORD ,lparam:DWORD
cmp [wmsg],WM_DESTROY
je .wmdestroy
lea eax,[WindowContext]
push eax
call Update_Window
invoke DefWindowProcA,[hwnd],[wmsg],[wparam],[lparam]
ret 
.wmdestroy: 
invoke PostQuitMessage,0
xor eax,eax
ret 
WindowProc.retn: 
ret 
endp
